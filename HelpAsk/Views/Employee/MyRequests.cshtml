@model List<HelpAsk.Models.Request>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Мои обращения";
    var isItDepartment = ViewBag.IsItDepartment;
    var pendingStatusId = ViewBag.PendingStatusId;
    var completedStatusId = ViewBag.CompletedStatusId;
}

<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/Employee"><i class="bi bi-question-circle me-2"></i>HelpAsk</a>
        <div class="d-flex align-items-center">
            <span class="text-white me-3">
                <i class="bi bi-person-circle me-1"></i>
                @Context.User.Identity?.Name
            </span>
            <a href="/Account/Logout" class="btn btn-outline-light btn-sm">
                <i class="bi bi-box-arrow-right me-1"></i>Выйти
            </a>
        </div>
    </div>
</nav>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4><i class="bi bi-list-check me-2"></i>Мои обращения</h4>
        <a href="/Employee/CreateRequest" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Создать обращение
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Тема</th>
                    <th>Услуга</th>
                    <th>Оборудование</th>
                    <th>Статус</th>
                    <th>Срочность</th>
                    <th>Дата создания</th>
                    <th>Оценка</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.StatusId == completedStatusId ? "table-success" : "")">
                            <td>@item.Id</td>
                            <td>@item.Subject</td>
                            <td>@item.Service.Title</td>
                            <td>@(item.Equipment != null ? $"{item.Equipment.EquipmentType.Title} {item.Equipment.EquipmentModel.Title} ({item.Equipment.EquipmentModel.Manufacturer.Title})" : "—")</td>
                            <td><span class="badge bg-@(item.Status.Title == "Выполнено" ? "success" : "warning")">@item.Status.Title</span></td>
                            <td>@item.Urgency.Title</td>
                            <td>@item.CreationDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (item.Status.Title == "Выполнено" && item.RatingId == null)
                                {
                                    <form asp-action="SetRating" method="post" class="d-flex gap-1">
                                        <input type="hidden" name="requestId" value="@item.Id" />
                                        <select name="ratingId" class="form-select form-select-sm" style="width:120px" required>
                                            <option value="">Оценить</option>
                                            @if (ViewBag.Ratings != null)
                                            {
                                                @foreach (var r in ViewBag.Ratings)
                                                {
                                                    <option value="@r.Value">@r.Text</option>
                                                }
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check"></i></button>
                                    </form>
                                }
                                else if (item.Rating != null)
                                {
                                    <span class="badge bg-info">@item.Rating.Title</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    @if (item.Status.Title == "В ожидании")
                                    {
                                        <a href="/Employee/Chat/@item.Id" class="btn btn-sm btn-outline-primary" title="Чат">
                                            <i class="bi bi-chat-dots"></i>
                                        </a>
                                        <a href="/Employee/EditRequest/@item.Id" class="btn btn-sm btn-outline-warning" title="Редактировать">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (isItDepartment)
                                        {
                                            <form asp-action="CompleteRequest" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-success" title="Выполнить">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="DeleteRequest" method="post" class="d-inline" onsubmit="return confirm('Удалить обращение?');">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">У вас пока нет обращений</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <a href="/Employee" class="btn btn-secondary mt-3">
        <i class="bi bi-arrow-left me-1"></i>На главную
    </a>
</div>
