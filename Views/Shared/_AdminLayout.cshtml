<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HelpAsk</title>
    <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/lib/bootstrap-icons/css/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Admin"><i class="bi bi-shield-lock me-2"></i>HelpAsk Admin</a>
            <div class="d-flex align-items-center">
                <span class="text-white me-3">
                    <i class="bi bi-person-circle me-1"></i>
                    @Context.User.Identity?.Name
                </span>
                <a href="/Account/Logout" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-box-arrow-right me-1"></i>Выйти
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid py-4">
        <div class="row g-4">
            <div class="col-md-2">
                <div class="sidebar">
                    <nav class="nav flex-column">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" href="/Admin">
                            <i class="bi bi-people me-2"></i>Пользователи
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Positions" ? "active" : "")" href="/Admin/Positions">
                            <i class="bi bi-briefcase me-2"></i>Должности
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Departments" ? "active" : "")" href="/Admin/Departments">
                            <i class="bi bi-building me-2"></i>Отделы
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Statuses" ? "active" : "")" href="/Admin/Statuses">
                            <i class="bi bi-check-circle me-2"></i>Статусы
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "UrgencyLevels" ? "active" : "")" href="/Admin/UrgencyLevels">
                            <i class="bi bi-exclamation-triangle me-2"></i>Срочности
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Ratings" ? "active" : "")" href="/Admin/Ratings">
                            <i class="bi bi-star me-2"></i>Оценки
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Categories" ? "active" : "")" href="/Admin/Categories">
                            <i class="bi bi-folder me-2"></i>Категории
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Subcategories" ? "active" : "")" href="/Admin/Subcategories">
                            <i class="bi bi-folder2-open me-2"></i>Подкатегории
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "EquipmentTypes" ? "active" : "")" href="/Admin/EquipmentTypes">
                            <i class="bi bi-hdd me-2"></i>Типы оборудования
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Countries" ? "active" : "")" href="/Admin/Countries">
                            <i class="bi bi-globe me-2"></i>Страны
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Manufacturers" ? "active" : "")" href="/Admin/Manufacturers">
                            <i class="bi bi-box-seam me-2"></i>Производители
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "EquipmentModels" ? "active" : "")" href="/Admin/EquipmentModels">
                            <i class="bi bi-cpu me-2"></i>Модели оборудования
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Equipment" ? "active" : "")" href="/Admin/Equipment">
                            <i class="bi bi-pc-display-horizontal me-2"></i>Оборудование
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Services" ? "active" : "")" href="/Admin/Services">
                            <i class="bi bi-tools me-2"></i>Услуги
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Requests" ? "active" : "")" href="/Admin/Requests">
                            <i class="bi bi-envelope-paper me-2"></i>Обращения
                        </a>
                    </nav>
                </div>
            </div>
            <div class="col-md-10">
                <div class="main-content">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
